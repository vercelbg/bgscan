# ------------------------------------
# General & Hugo Build Artifacts
# ------------------------------------
*.txt
public/
resources/
.hugo_build.lock
.docs-replacement-holder

# Explicitly ignore Hugo build folders inside docs 
docs/public/
docs/resources/

# ------------------------------------
# Go Build & Binary Files
# ------------------------------------
/bin/
/build/
/dist/
/out/
/coverage/
/tmp/

# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
__debug_bin*

# Go modules (CRITICAL: go.sum MUST be tracked, only ignore vendor)
/vendor/

# Logs & Local Results
*.log
/[Ll]ogs/
/result/
/[Tt]mp/

# Dependency directories
pkg/
**/pkg/

# Local environment files
.env
*.local

# ------------------------------------
# Project Specific (Assets, Settings, IPs)
# ------------------------------------

# Ignore everything in the root assets folder (binaries like dnstt-client)
assets/*

# Allow xray directory and its contents, except the actual compiled binary and dat files
!assets/xray/
assets/xray/xray*
assets/xray/*.dat
assets/xray/configs/
assets/xray/outbounds/*.json

# Allow example files to be tracked
!assets/xray/outbounds/*.example

# Ignore local user settings and generated IP lists (keeps .default files tracked)
settings/*.toml
ips/*.csv

# Ignore local builder output
bgscan-builder*

# ------------------------------------
# IDE / Editor Ignores
# ------------------------------------

# VSCode
.vscode/
.history/

# JetBrains IDEs (GoLand, IntelliJ IDEA, etc.)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Emacs
*.swp
*.swo
*.vim
*~
\#*\#
.\#*

# OS specific
.DS_Store
Thumbs.db
